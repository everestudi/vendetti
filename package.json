{
  "name": "vendetti",
  "version": "0.1.0",
  "private": true,
  "description": "Augusto Vendetti — agente CEO da vending machine TCN Pro 6G no Blue Mall Rondon",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "scrape:login": "dotenv -e .env.local -- tsx src/scrapers/vendtef/login.ts",
    "scrape:sales": "dotenv -e .env.local -- tsx src/scrapers/vendtef/sales.ts",
    "scrape:inventory": "dotenv -e .env.local -- tsx src/scrapers/vendtef/inventory.ts",
    "agent:tick": "dotenv -e .env.local -- tsx src/lib/augusto/tick.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.142",
    "@anthropic-ai/sdk": "^0.96.0",
    "@prisma/client": "^7.8.0",
    "ai": "^6.0.182",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.5.14",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
