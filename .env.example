# =============================================================
# Augusto Vendetti — variáveis de ambiente
# Copie para .env.local (dev) e configure no Vercel/Railway (prod)
# =============================================================
# OBJETIVO: manter APENAS o mínimo aqui. API keys de operação
# (Anthropic, Resend, Z-API, ERP Vending) ficam cifradas no banco
# via /settings — NÃO precisam estar nesse arquivo.
# =============================================================

# --- Database (Neon Postgres recomendado) ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Auth bootstrap ---
# Gere com: openssl rand -base64 32
AUTH_SECRET=
# Senha do /login (MVP — depois trocamos por magic link)
BOOTSTRAP_PASSWORD=

# --- App ---
NEXTAUTH_URL=http://localhost:3000

# =============================================================
# Tudo abaixo é OPCIONAL — preencha pelo /settings na UI.
# Os campos abaixo só são lidos se /settings não tiver o valor.
# =============================================================
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-7
# RESEND_API_KEY=
# EMAIL_FROM=vendetti@everest.udi.br
# EMAIL_OPS=luisnetodg@gmail.com
# ERPVENDING_USER=
# ERPVENDING_PASS=
# ZAPI_INSTANCE=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=
# WEVERTON_PHONE=
# AUGUSTO_PHONE=
# ATACADAO_USER=
# ATACADAO_PASS=
# OBSIDIAN_VAULT_PATH=/Users/luisneto/Documents/Obsidian Vault
