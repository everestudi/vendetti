// Vendetti — schema inicial.
// Foco em: catálogo, slots da máquina, transações, reposições, decision log.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// === Catálogo ===

model Sku {
  id              String   @id @default(cuid())
  code            String   @unique // código no Vendtef
  name            String
  category        String   // bebida, barrinha, salgadinho, doce, ...
  supplier        Supplier
  supplierSkuCode String?  // ref no Atacadão / Vittal
  cost            Decimal  @db.Decimal(10, 2)
  price           Decimal  @db.Decimal(10, 2)
  marginPct       Decimal? @db.Decimal(5, 2) // (price - cost) / price * 100
  /// URL da imagem do produto (CDN do fornecedor, geralmente Atacadão VTEX).
  /// Populada pelo Bruno via fetchProductImage. Renderizada nos tiles da
  /// máquina ao invés do emoji genérico quando presente.
  imageUrl        String?  @db.Text
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  slots           Slot[]
  transactions    Transaction[]
  reposicoes      ReposicaoItem[]
  purchaseItems   PurchaseItem[]
  everestStock    EverestStock?
}

enum Supplier {
  ATACADAO
  VITTAL
  OUTRO
}

/// Estado atual do estoque Everest (warehouse compartilhado).
/// Atualizado pela Mara a cada sync — scraper navega em /erp/estoques/everest/
/// produtos-configurados e captura a tabela.
///
/// Single row por SKU (atual). Histórico não é necessário aqui — a evolução
/// é capturada em Reposicao (entradas) + Transaction (saídas indiretas via
/// abastecimento da máquina).
model EverestStock {
  id        String   @id @default(cuid())
  skuId     String   @unique
  sku       Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)
  qty       Int      // quantidade atual no Everest
  alerta    Int      // limite pra alerta
  critico   Int      // limite pra crítico
  /// Status capturado pelo Vendtef (ok / alerta / crítico). String aberta.
  status    String?
  updatedAt DateTime @updatedAt
  capturedAt DateTime @default(now())

  @@index([qty])
  @@index([status])
}

// === Máquina física ===

model Machine {
  id            String              @id @default(cuid())
  name          String              @unique
  model         String
  location      String
  active        Boolean             @default(true)
  slots         Slot[]
  snapshots     InventorySnapshot[]
  dailyRevenue  DailyRevenue[]
  createdAt     DateTime            @default(now())
}

model Slot {
  id              String   @id @default(cuid())
  machineId       String
  machine         Machine  @relation(fields: [machineId], references: [id])
  /// Identificador da seleção no Vendtef (ex: "1", "11", "33").
  position        String
  skuId           String?
  sku             Sku?     @relation(fields: [skuId], references: [id])
  capacity        Int      @default(15)
  currentQty      Int      @default(0)
  /// Preço de venda (lido do modal Seleções).
  price           Decimal? @db.Decimal(10, 2)
  /// Lucro estimado por unidade (lido do Vendtef como "Lucro Estimado").
  marginEst       Decimal? @db.Decimal(10, 2)
  qtdeAlerta      Int?
  qtdeCritico     Int?
  updatedAt       DateTime @updatedAt

  @@unique([machineId, position])
}

/// Faturamento por dia, da tabela `Faturamento Diário` do Vendtef.
model DailyRevenue {
  id           String   @id @default(cuid())
  machineId    String
  machine      Machine  @relation(fields: [machineId], references: [id])
  date         DateTime @db.Date
  qtdTotal     Int
  qtdTef       Int      @default(0)
  qtdPix       Int      @default(0)
  qtdCash      Int      @default(0)
  qtdPrivate   Int      @default(0)
  totalTef     Decimal  @default(0) @db.Decimal(10, 2)
  totalPix     Decimal  @default(0) @db.Decimal(10, 2)
  totalCash    Decimal  @default(0) @db.Decimal(10, 2)
  totalPrivate Decimal  @default(0) @db.Decimal(10, 2)
  totalRevenue Decimal  @default(0) @db.Decimal(10, 2)
  totalCost    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([machineId, date])
  @@index([date])
}

/// Snapshot diário do estado de inventário da máquina.
model InventorySnapshot {
  id                String   @id @default(cuid())
  machineId         String
  machine           Machine  @relation(fields: [machineId], references: [id])
  capturedAt        DateTime @default(now())
  slotsTotal        Int
  slotsOk           Int
  slotsAlert        Int
  slotsCritical     Int
  /// Percentual de capacidade preenchida (0-100).
  capacityFilledPct Decimal? @db.Decimal(5, 2)

  @@index([machineId, capturedAt])
}

// === Vendas e pagamentos ===

model Transaction {
  id              String   @id @default(cuid())
  /// Nº lógico do Vendtef (idx 13 do CSV) — UUID-like, único.
  vendpagoId      String?  @unique
  occurredAt      DateTime
  skuId           String?
  sku             Sku?     @relation(fields: [skuId], references: [id])
  slotPosition    String?
  qty             Int      @default(1)
  grossAmount     Decimal  @db.Decimal(10, 2)
  netAmount       Decimal? @db.Decimal(10, 2)
  /// "TEF", "PIX", "CASH", "PRIVATE LABEL" — copiado direto do Vendtef.
  paymentType     String?
  status          TransactionStatus @default(OK)
  /// Quando status = FAILED, motivo do cancelamento (ex: "PagBank: NAO AUTORIZADA").
  failureReason   String?  @db.Text
  /// Categoria normalizada: USER_CANCEL | CARD_DENIED | OP_CANCELLED | NO_SELECTION | OTHER
  failureCategory String?
  rawJson         Json?
  createdAt       DateTime @default(now())

  @@index([occurredAt])
  @@index([skuId, occurredAt])
  @@index([status, occurredAt])
}

enum TransactionStatus {
  OK
  FAILED       // pagou e não saiu
  REFUNDED
  COMPLAINT    // reclamação registrada
}

// === Reposições (físicas, feitas pelo Weverton) ===

model Reposicao {
  id          String   @id @default(cuid())
  occurredAt  DateTime @default(now())
  reportedBy  String   // "weverton", "neto"
  source      Source   @default(WHATSAPP_AUGUSTO)
  notes       String?
  photoUrl    String?
  itens       ReposicaoItem[]
  syncedAt    DateTime? // quando o Vendetti refletiu no Vendtef
  createdAt   DateTime @default(now())
}

enum Source {
  WHATSAPP_LUIS
  WHATSAPP_AUGUSTO
  PWA_OPERADOR
  MANUAL
}

model ReposicaoItem {
  id            String    @id @default(cuid())
  reposicaoId   String
  reposicao     Reposicao @relation(fields: [reposicaoId], references: [id], onDelete: Cascade)
  skuId         String
  sku           Sku       @relation(fields: [skuId], references: [id])
  slotPosition  String?
  qty           Int
}

// === Compras (entrada via NF-e — foto/PDF/manual) ===

/// Compra de produtos no fornecedor (Atacadão, Vittal, etc).
/// Origem: foto/PDF da NF-e parseada via vision, ou cadastro manual.
model Purchase {
  id           String   @id @default(cuid())
  occurredAt   DateTime // data da NF (não created)
  supplier     Supplier
  supplierName String?  // razão social cru da NF (livre)
  invoiceRef   String?  // nº NF-e
  invoiceUrl   String?  // URL da imagem/PDF salva
  totalAmount  Decimal  @db.Decimal(10, 2)
  notes        String?  @db.Text
  /// Origem: "ui-upload", "whatsapp-luis", "manual"
  source       String   @default("manual")
  rawParsed    Json?    // saída cru do parser (audit)
  /// Sync com Vendtef (entrada de estoque + cadastro de produto novo se preciso).
  /// Setado pelo GH Action `vendtef-sync` rodando Playwright.
  vendtefSyncedAt   DateTime?
  vendtefSyncError  String?   @db.Text
  vendtefSyncAttempts Int       @default(0)
  itens        PurchaseItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([occurredAt])
  @@index([supplier, occurredAt])
  @@index([vendtefSyncedAt])
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  skuId       String?
  sku         Sku?     @relation(fields: [skuId], references: [id])
  productName String   // nome cru da NF
  productCode String?  // GTIN/EAN ou código fornecedor
  qty         Int
  unitCost    Decimal  @db.Decimal(10, 2)
  totalCost   Decimal  @db.Decimal(10, 2)
}

// === Decision log do Vendetti (append-only) ===

model Decision {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  kind        DecisionKind
  level       AutonomyLevel // GREEN, YELLOW, RED
  summary     String
  rationale   String       @db.Text
  data        Json         // input/output da decisão
  status      DecisionStatus @default(PENDING)
  executedAt  DateTime?
  approvedBy  String?
  rejectedBy  String?
  rejectReason String?

  @@index([createdAt])
  @@index([kind, status])
}

enum DecisionKind {
  PRICE_CHANGE
  RESTOCK_ORDER          // compra no fornecedor
  RESTOCK_TASK           // tarefa pro Weverton
  SLOT_REORG
  SKU_ADD
  SKU_REMOVE
  REFUND
  COMPLAINT_RESPONSE
  SYSTEM_INVENTORY_SYNC  // alimentar Vendtef após reposição
  OTHER
}

enum AutonomyLevel {
  GREEN  // Vendetti executa sozinho
  YELLOW // 1-clique do Luís
  RED    // chat obrigatório
}

enum DecisionStatus {
  PENDING                       // aguarda aprovação do Luís
  APPROVED                      // Luís aprovou — Rita vai executar
  REJECTED
  AWAITING_PHYSICAL             // sistema atualizado, aguarda Weverton confirmar mudança física (etiqueta/painel)
  EXECUTED                      // tudo concluído (sistema + físico)
  FAILED
}

// === Reclamações ===

/// Reclamação de cliente da vending machine — tratada pela Lúcia (SAC).
model Complaint {
  id                 String           @id @default(cuid())
  receivedAt         DateTime         @default(now())
  /// "zapi", "whatsapp-corporativo", "manual"
  source             String
  customerPhone      String?
  customerNote       String           @db.Text
  /// Slot reportado pelo cliente (ex: "13").
  slotPosition       String?
  /// URL de comprovante (foto/print enviada pelo cliente).
  proofUrl           String?
  /// Match com Transaction no Vendpago (se Lúcia conseguir cruzar).
  transactionId      String?
  /// Resultado do cruzamento: true se achou venda do slot+horário no banco
  transactionMatched Boolean?
  status             ComplaintStatus  @default(RECEIVED)
  resolution         String?          @db.Text
  resolvedAt         DateTime?
  refundAmount       Decimal?         @db.Decimal(10, 2)
  escalatedAt        DateTime?
  /// Contador de mensagens enviadas pela Lúcia. Max 4 antes de silenciar.
  luciaMessageCount  Int              @default(0)
  /// Último timestamp de msg do cliente — usado pra detectar abandono (>2h).
  lastClientMessageAt DateTime?
  /// Conversa completa em jsonl
  conversation       Json?

  @@index([customerPhone, status])
  @@index([status, lastClientMessageAt])
}

enum ComplaintStatus {
  RECEIVED            // chegou inbound, triagem pendente (transitório)
  TRIAGE_REJECTED     // não é SAC válido — silenciado
  AWAITING_PROOF      // legado — Lúcia pediu comprovante (migrar pra AWAITING_INFO)
  AWAITING_SLOT       // legado — Lúcia pediu slot (migrar pra AWAITING_INFO)
  AWAITING_INFO       // novo: pediu print+slot juntos, esperando
  ESCALATED           // mastigado e enviado pro Luís
  ASSUMED_BY_LUIS     // Luís assumiu via /assumir, Lúcia muta
  REFUNDED
  DISMISSED
  ABANDONED           // cliente não respondeu em 2h após escalation
}

/// Inquiry · guarda-chuva pra qualquer mensagem que não é SAC_VENDING.
/// Locação de loja, estacionamento, dúvidas gerais — tudo passa por aqui.
/// Lúcia classifica via LLM (Haiku 4.5), responde 1x cordialmente e escala
/// pro Luís com tag de categoria.
model Inquiry {
  id              String          @id @default(cuid())
  receivedAt      DateTime        @default(now())
  customerPhone   String
  customerName    String?
  source          String          @default("zapi")
  /// Categoria detectada pelo classificador. String aberta pra extensão futura
  /// (novas categorias sem mexer no schema).
  category        String
  /// Resumo curto gerado pelo classificador (max 60 chars).
  subject         String?
  originalMessage String          @db.Text
  conversation    Json?
  status          InquiryStatus   @default(NEW)
  assignedTo      String?         // "luis", "lucia", futuro: outros agentes
  resolution      String?         @db.Text
  resolvedAt      DateTime?
  /// Stage do funil (só pra category=LEAD_LOCACAO)
  leadStage       LeadStage?
  /// Detalhes flexíveis: tamanho/tipo de loja, valor estimado, etc
  leadDetails     Json?
  /// Quantas msgs a Lúcia já mandou (cap 4 igual SAC)
  luciaMessageCount Int           @default(0)
  lastClientMessageAt DateTime?
  updatedAt       DateTime        @updatedAt

  @@index([customerPhone])
  @@index([category, status])
  @@index([leadStage, status])
  @@index([receivedAt])
}

enum InquiryStatus {
  NEW             // recém-chegada
  ACKNOWLEDGED    // Lúcia respondeu o cliente cordialmente
  ESCALATED       // repassada pro Luís via WhatsApp
  IN_PROGRESS     // Luís está tratando
  ASSUMED_BY_LUIS // Luís assumiu, Lúcia muta
  RESOLVED
  DISMISSED
  ABANDONED
}

enum LeadStage {
  PRE_QUALIFICACAO  // chegou, sem detalhes
  QUALIFICADO       // tem informações básicas (tipo, tamanho, prazo)
  EM_NEGOCIACAO
  PROPOSTA_ENVIADA
  CONVERTIDO
  PERDIDO
}

// === Secrets (cifrados em AES-256-GCM com chave derivada de AUTH_SECRET) ===

model Secret {
  key       String   @id // ex: "ANTHROPIC_API_KEY"
  value     String   @db.Text // ciphertext base64 (iv|tag|data)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// === Histórico do chat com o Augusto Vendetti ===

/// Mensagens persistidas do /chat e /vendetti. Por enquanto uma única sessão
/// global do admin (Luís). Pra multi-user / multi-sessão, basta adicionar
/// sessionId e indexar.
model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // 'user' | 'assistant' | 'system'
  /// JSON serializado dos `parts` (text + tool calls + tool results)
  parts     Json
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// === Infra · saúde dos workers/jobs ===

/// Cada execução de worker/job grava uma entrada aqui. Permite ao Vendetti
/// detectar staleness por conta própria via tool `infra_health`.
model WorkerRun {
  id          String   @id @default(cuid())
  /// Nome canônico do worker: "mara_sync", "vendtef_entrada", "sac_cleanup", ...
  name        String
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  /// "RUNNING" | "OK" | "FAILED"
  status      String   @default("RUNNING")
  /// Mensagem de erro / aviso (null se OK)
  error       String?  @db.Text
  /// JSON livre: contagem de items processados, IDs afetados, etc
  meta        Json?

  @@index([name, startedAt])
  @@index([status, startedAt])
}


// === Caixa de ideias (Luís joga, discutimos depois) ===

model Idea {
  id         String     @id @default(cuid())
  content    String     @db.Text
  status     IdeaStatus @default(NEW)
  /// Nota opcional quando resolvida (ex: "entrou no Sprint 7", "rejeitado pq X").
  note       String?    @db.Text
  createdAt  DateTime   @default(now())
  resolvedAt DateTime?

  @@index([status, createdAt])
}

enum IdeaStatus {
  NEW
  RESOLVED
}

// === Auth (NextAuth) ===

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN     // Luís
  OPERADOR  // Weverton
  VIEWER
}

// ============================================================
// === Runtime de agentes — "empresa virtual" Vendetti     ===
// ============================================================
// Schema desenhado em mai/2026 pra transformar os "6 agentes" (que eram
// teatro de UI) em agentes reais rodando em paralelo, com mailbox + memória
// + schedules. Doc completo em docs/research/MULTI_AGENT_ARCHITECTURE.md.
//
// Patterns roubados de:
//   - Paperclip (paperclipai/paperclip): wakeup coalescing, mailbox unificado,
//     adapter contract com cost tracking, atomic checkout
//   - Letta/MemGPT: memória 3-tier (Core / Recall / Archival)
//   - LangGraph: handoffs explícitos + checkpointing visível
//   - Mastra: agents-as-tools quando supervisor precisa delegar

/// Definição de um agente da empresa Vendetti.
/// `promptCore` = memória Core (sempre in-context). Resto é Recall via
/// AgentMemoryRecall (semantic search) + Archival via cold storage.
model Agent {
  id              String   @id @default(cuid())
  /// Identificador estável usado em handoffs e cross-refs. Ex: 'augusto', 'mara'.
  slug            String   @unique
  name            String
  emoji           String
  /// Descrição curta — aparece na UI /empresa.
  role            String
  /// Prompt Core (identidade + regras invioláveis + alavancas). NÃO inclui
  /// dados operacionais — esses vêm do contexto montado a cada run.
  promptCore      String   @db.Text
  /// Versionamento de prompt — incrementa quando o Luís ou Gabi (co-founder)
  /// edita. Audit em AgentPromptRevision (futuro).
  promptRev       Int      @default(1)
  /// Modelo Anthropic a usar. Ex: 'claude-opus-4-7', 'claude-sonnet-4-5-20250929'.
  model           String
  /// Subset de tool slugs que esse agente pode invocar. Empty = sem tools (só LLM).
  toolsAllowed    String[]
  /// Budget mensal em USD. Hard-stop quando ultrapassado (rouba do Paperclip).
  budgetUsdMonth  Decimal  @default(50) @db.Decimal(8, 2)
  /// Quanto já gastou no mês corrente (resetado por cron mensal).
  spentUsdMonth   Decimal  @default(0)  @db.Decimal(10, 4)
  /// Hierarquia — ex: mara/bruno/rita/zelda/lucia reportam pro augusto.
  reportsToSlug   String?
  /// Quando true (default no começo), TODA decisão/ação concreta desse agente
  /// cria Decision em status AWAITING_HUMAN e espera Luís aprovar. Desligar
  /// quando confiança crescer. Mensagens NOTE/INSIGHT/QUESTION ainda fluem livres.
  humanInLoop     Boolean  @default(true)
  /// Ativo no sistema. false = desabilitado permanente (não roda nem aceita msg).
  active          Boolean  @default(true)
  /// Pausa temporária — botão de pânico. paused=true → tick pula esse agente
  /// e wakeups novos ficam QUEUED sem processar. Diferente de active=false
  /// porque mantém histórico/mailbox acessível.
  paused          Boolean  @default(false)
  /// Motivo da pausa (preenchido pelo botão de pânico).
  pausedReason    String?
  pausedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  runs            AgentRun[]
  wakeups         AgentWakeupRequest[]
  messagesFrom    AgentMessage[]       @relation("fromAgent")
  messagesTo      AgentMessage[]       @relation("toAgent")
  recalls         AgentMemoryRecall[]

  @@index([slug])
  @@index([active])
}

/// Cada execução de um agente — um turn do agentic loop.
/// Mostra "como ele pensou": thinkingMd visível na UI /empresa pro Luís.
model AgentRun {
  id            String   @id @default(cuid())
  agentId       String
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  /// O que disparou esse run.
  trigger       AgentTrigger
  /// Ref opcional pro que disparou (msgId / wakeupId / userId).
  triggerRef    String?
  status        AgentRunStatus @default(RUNNING)
  /// Chain-of-thought renderizado em markdown — visível na UI.
  /// Quando o modelo é Opus 4.7 com extended thinking, salva o thinking block.
  thinkingMd    String?  @db.Text
  /// Output final do agente (markdown).
  outputMd      String?  @db.Text
  /// Log estruturado de tool calls: [{ name, input, output, ms }, ...].
  toolCalls     Json?
  /// Handoff sugerido pelo agente — outro slug que deve ser invocado a seguir.
  nextAgentSlug String?
  /// Custo dessa run em USD (input+output tokens × preço modelo).
  costUsd       Decimal  @default(0) @db.Decimal(10, 6)
  tokensIn      Int      @default(0)
  tokensOut    Int      @default(0)
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  errorMsg      String?  @db.Text

  generatedMessages AgentMessage[] @relation("runGenerated")

  @@index([agentId, startedAt(sort: Desc)])
  @@index([status])
}

enum AgentTrigger {
  /// GH Actions cron chamou /api/tick e esse agente tinha schedule due.
  CRON
  /// Outra agente (ou humano) mandou mensagem pra esse agente.
  MAILBOX
  /// Luís acionou direto via /chat ou botão "falar com X".
  ON_DEMAND
  /// Evento do sistema disparou (ex: Decision criada → Zelda audita).
  AUTOMATION
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
  /// Budget mensal estourou — agente pausado até reset.
  BUDGET_STOPPED
  /// Foi superseded por um run mais recente (coalescing).
  COALESCED
}

/// Mailbox unificado — humano + agentes na mesma timeline (rouba do Paperclip).
/// Toda comunicação passa por aqui. UI /empresa renderiza feed disso.
model AgentMessage {
  id              String   @id @default(cuid())
  /// Quem mandou. null = humano (Luís).
  fromAgentId     String?
  fromAgent       Agent?   @relation("fromAgent", fields: [fromAgentId], references: [id], onDelete: SetNull)
  /// Pra quem. null = broadcast (todos veem). Mailbox público por default.
  toAgentId       String?
  toAgent         Agent?   @relation("toAgent", fields: [toAgentId], references: [id], onDelete: SetNull)
  /// ThreadId pra agrupar conversa (mesmo assunto, várias msgs).
  threadId        String?
  /// Categoria — pra UI filtrar e priorizar.
  kind            AgentMessageKind @default(NOTE)
  /// Body em markdown.
  body            String   @db.Text
  /// Refs estruturadas: { decisionId?, slotPosition?, skuCode?, txId?, ... }.
  refs            Json?
  status          AgentMessageStatus @default(DELIVERED)
  /// Se essa msg foi gerada por uma run, qual.
  triggeredByRunId String?
  triggeredByRun   AgentRun? @relation("runGenerated", fields: [triggeredByRunId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  readAt          DateTime?

  @@index([toAgentId, status, createdAt])
  @@index([threadId])
  @@index([createdAt(sort: Desc)])
}

enum AgentMessageKind {
  /// Nota geral, FYI.
  NOTE
  /// Pergunta direta, espera resposta.
  QUESTION
  /// Insight/finding (análise da Mara, descoberta do Bruno).
  INSIGHT
  /// Ação proposta pra outro agente executar.
  REQUEST
  /// Alerta — algo crítico, prioridade alta.
  ALERT
  /// Proposta da Gabi pro próprio produto Vendetti.
  PROPOSAL
}

enum AgentMessageStatus {
  DELIVERED
  READ
  /// Outro agente já agiu sobre essa msg (criou Decision, mandou Z-API, etc).
  ACTIONED
  /// Mensagem foi rejeitada/ignorada pelo destinatário com motivo em refs.
  DISMISSED
}

/// Fila de wakeups com coalescing (rouba do Paperclip).
/// Múltiplos wakes pro mesmo agente em janela curta viram um único run.
/// idempotencyKey previne duplicação cross-process.
model AgentWakeupRequest {
  id              String   @id @default(cuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  trigger         AgentTrigger
  /// Ref opcional do que disparou (mailboxMsgId / cronJobName / userId).
  triggerRef      String?
  status          AgentWakeupStatus @default(QUEUED)
  /// Chave de idempotência — formato: '<agentSlug>:<trigger>:<refOrHash>'.
  /// Wakes duplicados com mesma key incrementam coalescedCount em vez de duplicar.
  idempotencyKey  String?  @unique
  coalescedCount  Int      @default(0)
  /// Payload custom — ex: { messageId, hint }.
  payload         Json?
  createdAt       DateTime @default(now())
  claimedAt       DateTime?
  completedAt     DateTime?
  /// RunId que processou esse wakeup, se algum.
  processedByRunId String?

  @@index([status, createdAt])
  @@index([agentId, status])
}

enum AgentWakeupStatus {
  QUEUED
  /// Algum tick worker pegou pra processar (lock atômico).
  CLAIMED
  COMPLETED
  FAILED
  /// Outro wake com mesma idempotencyKey já completou — esse foi mesclado.
  COALESCED
}

/// Memória Recall — searchable history que o agente carrega seletivo.
/// Ex: "última vez que vimos água zero crítica", "decisão de preço Red Bull
/// em out/25", "Weverton avisou Y em mar/26". Por enquanto keyword search no
/// body; PR 3 adiciona embedding pra semantic search.
model AgentMemoryRecall {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  kind        AgentMemoryKind
  /// Sumário curto (~200 chars) — usado em keyword search inicial.
  summary     String
  /// Corpo completo do que vale lembrar.
  body        String   @db.Text
  /// Refs estruturadas (decisionId, msgId, etc).
  refs        Json?
  /// Quantas vezes esse recall já foi promovido pro context — feedback signal.
  hitCount    Int      @default(0)
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?

  @@index([agentId, kind])
  @@index([agentId, lastUsedAt(sort: Desc)])
}

enum AgentMemoryKind {
  /// Decisão tomada e por quê.
  DECISION
  /// Padrão observado nos dados.
  INSIGHT
  /// Erro cometido + correção (pra não repetir).
  MISTAKE
  /// Trecho de conversa relevante com o Luís.
  CONVERSATION
  /// Regra invariante (escala de Core mas guarda aqui se for nicho).
  RULE
}
